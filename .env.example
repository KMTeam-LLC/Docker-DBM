# =============================================================================
# Docker-DBM Environment Configuration
# Powered by KMTeam LLC
# =============================================================================
# 
# SECURITY WARNING: This file contains sensitive credentials.
# - NEVER commit this file to version control with real values
# - Copy to .env and fill in your actual values
# - Add .env to your .gitignore file
#
# =============================================================================

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
# Specify the database engine to provision
# Supported values: postgres, mariadb
DB_TYPE=postgres

# =============================================================================
# ROOT/ADMIN CREDENTIALS
# =============================================================================
# These credentials are used by Docker-DBM to connect as an administrator
# and create new databases and users.
#
# SECURITY CRITICAL:
# - These credentials should ONLY be exposed to the docker-dbm container
# - NEVER expose these to your application containers
# - Consider using Docker secrets in production

# Hostname of your centralized database server
# Use Docker network DNS name if DB is in a container (e.g., shared_db)
DB_HOST=shared_postgres

# Port number for the database server
# PostgreSQL default: 5432
# MariaDB/MySQL default: 3306
DB_PORT=5432

# Administrator username with CREATE DATABASE and CREATE USER privileges
# PostgreSQL default: postgres
# MariaDB default: root
ADMIN_USER=postgres

# Administrator password
# CHANGE THIS in production!
ADMIN_PASS=your_admin_password_here

# =============================================================================
# APPLICATION CREDENTIALS
# =============================================================================
# These are the credentials for the new database and user that Docker-DBM
# will create for your application.
#
# These credentials CAN be safely exposed to your application container.

# Name of the database to create
APP_DB_NAME=myapp_database

# Username for the application to use
APP_DB_USER=myapp_user

# Password for the application user
# Use a strong, unique password for each application!
APP_DB_PASS=your_app_password_here
